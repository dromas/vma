<!DOCTYPE html>
<html lang="it">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
<meta name="theme-color" content="#C8282A">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="Viareggio">
<meta name="description" content="Viareggio mon Amour — App ufficiale della campagna elettorale 2026">
<link rel="manifest" href="manifest.json">
<link rel="apple-touch-icon" href="icons/icon-192.png">
<title>Viareggio mon Amour</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Dancing+Script:wght@700&family=DM+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&display=swap" rel="stylesheet">
<style>
/* ===================================================
   RESET & ROOT
=================================================== */
:root {
  --blu: #1A3F8F;
  --blu-dark: #0d2260;
  --blu-light: #dce8ff;
  --rosso: #C8282A;
  --rosso-light: #fde0e0;
  --verde: #1b7a4e;
  --verde-light: #d4f5e5;
  --amber: #b86800;
  --amber-light: #fff0cc;
  --bg: #F2F4F8;
  --white: #FFFFFF;
  --border: #E4E8F0;
  --testo: #14172b;
  --testo-2: #4a5270;
  --testo-3: #8891b0;
  --r: 14px;
  --r-sm: 10px;
  --shadow: 0 2px 14px rgba(26,63,143,.09);
  --safe-bottom: env(safe-area-inset-bottom, 0px);
  --safe-top: env(safe-area-inset-top, 0px);
}
*{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent;}
html{height:100%;-webkit-text-size-adjust:100%;}
body{
  font-family:'DM Sans',sans-serif;
  background:var(--rosso);
  color:var(--testo);
  height:100%;
  overflow:hidden;
  display:flex;
  flex-direction:column;
}

/* ===================================================
   LAYOUT SHELL
=================================================== */
#app{
  display:flex;
  flex-direction:column;
  height:100%;
  max-width:480px;
  margin:0 auto;
  width:100%;
  position:relative;
  overflow:hidden;
  background:var(--rosso);
  box-shadow:0 0 40px rgba(0,0,0,.18);
}

/* Safe area top padding for notched phones */
.safe-top{padding-top:var(--safe-top);}

/* ===================================================
   SCREENS
=================================================== */
.screen{
  display:none;
  flex-direction:column;
  flex:1;
  overflow:hidden;
  animation:fadeUp .2s ease;
}
.screen.active{display:flex;}
@keyframes fadeUp{from{opacity:0;transform:translateY(5px)}to{opacity:1;transform:translateY(0)}}

/* Admin screen variant */
.admin-screen{display:none;flex-direction:column;flex:1;overflow:hidden;}
.admin-screen.active{display:flex;animation:fadeUp .2s ease;}

/* Scrollable body */
.sc{flex:1;overflow-y:auto;-webkit-overflow-scrolling:touch;scrollbar-width:none;}
.sc::-webkit-scrollbar{display:none;}

/* ===================================================
   TRICOLOR BAR
=================================================== */
.tri{
  height:3px;flex-shrink:0;
  background:linear-gradient(to right,var(--blu) 33.3%,#fff 33.3%,#fff 66.6%,var(--rosso) 66.6%);
}

/* ===================================================
   PAGE HEADERS
=================================================== */
.ph{padding:16px 18px 20px;position:relative;overflow:hidden;flex-shrink:0;}
.ph.blu-grad{background:linear-gradient(150deg,var(--blu-dark) 0%,var(--blu) 55%,#2456c0 100%);}
.ph.rosso-grad{background:linear-gradient(150deg,#8c1010 0%,var(--rosso) 60%,#e04040 100%);}
.ph.verde-grad{background:linear-gradient(150deg,#0a4a2e 0%,#1b7a4e 60%,#27a96c 100%);}
.ph.amber-grad{background:linear-gradient(150deg,#6b3a00 0%,#c07010 60%,#e09020 100%);}
.ph::after{content:'';position:absolute;bottom:-40px;right:-20px;width:120px;height:120px;background:rgba(255,255,255,.05);border-radius:50%;}
.ph-title{font-family:'Bebas Neue',sans-serif;font-size:24px;letter-spacing:.06em;color:#fff;line-height:1;}
.ph-sub{font-size:13px;color:rgba(255,255,255,.72);margin-top:2px;}
.ph-icon{position:absolute;right:20px;top:50%;transform:translateY(-50%);font-size:32px;opacity:.75;}

/* ===================================================
   LOGO
=================================================== */
.logo-row{display:flex;align-items:center;gap:11px;margin-bottom:16px;}
.logo-bubble{width:44px;height:44px;background:#fff;border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:20px;box-shadow:0 4px 12px rgba(0,0,0,.2);flex-shrink:0;}
.logo-vr{font-family:'Bebas Neue',sans-serif;font-size:20px;color:#fff;letter-spacing:.06em;line-height:1;}
.logo-ma{font-family:'Dancing Script',cursive;font-size:15px;color:#ff9090;line-height:1.1;}

/* ===================================================
   BOTTOM NAV
=================================================== */
.bnav{
  background:var(--white);
  border-top:1px solid var(--border);
  padding:6px 0;
  padding-bottom:calc(6px + var(--safe-bottom));
  display:flex;justify-content:space-around;
  flex-shrink:0;
  position:relative;
  z-index:10;
}
.ni{
  display:flex;flex-direction:column;align-items:center;gap:2px;
  cursor:pointer;padding:5px 12px;border-radius:10px;
  transition:background .15s;min-width:56px;
  -webkit-user-select:none;user-select:none;
}
.ni:active{background:var(--bg);}
.ni.active .nicon{color:var(--blu);}
.ni.active .nlabel{color:var(--blu);font-weight:700;}
.nicon{font-size:22px;color:var(--testo-3);line-height:1;}
.nlabel{font-size:10px;color:var(--testo-3);font-weight:500;line-height:1;}
.notif-dot{
  position:absolute;top:0;right:0;
  width:8px;height:8px;border-radius:50%;
  background:var(--rosso);border:1.5px solid var(--white);
}
.ni-wrap{position:relative;display:inline-flex;}

/* ===================================================
   SECTION TITLE
=================================================== */
.stitle{
  font-size:15px;font-weight:700;color:var(--testo);
  padding:16px 16px 8px;
  display:flex;justify-content:space-between;align-items:center;
}
.stitle a{font-size:12px;font-weight:500;color:var(--blu);cursor:pointer;text-decoration:none;}

/* ===================================================
   CARDS
=================================================== */
.card{
  background:var(--white);border-radius:var(--r);
  box-shadow:var(--shadow);margin:0 14px 10px;
  overflow:hidden;cursor:pointer;
  transition:transform .15s,box-shadow .15s;
  -webkit-user-select:none;user-select:none;
}
.card:active{transform:scale(.98);box-shadow:none;}
.card-body{padding:13px 14px;}
.card-tag{font-size:10px;font-weight:700;letter-spacing:.06em;text-transform:uppercase;color:var(--blu);margin-bottom:4px;}
.card-tag.rosso{color:var(--rosso);}
.card-tag.verde{color:var(--verde);}
.card-tag.amber{color:var(--amber);}
.card-title{font-size:14px;font-weight:700;color:var(--testo);line-height:1.35;margin-bottom:3px;}
.card-desc{font-size:12px;color:var(--testo-2);line-height:1.5;}
.card-meta{font-size:11px;color:var(--testo-3);margin-top:5px;}

/* ===================================================
   EVENT CARDS
=================================================== */
.ecard{
  display:flex;gap:12px;align-items:flex-start;
  background:var(--white);border-radius:var(--r);
  box-shadow:var(--shadow);margin:0 14px 10px;padding:13px;
  cursor:pointer;transition:transform .15s;
}
.ecard:active{transform:scale(.98);}
.ebox{
  min-width:46px;height:50px;border-radius:10px;
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  color:#fff;flex-shrink:0;
}
.ebox.blu{background:var(--blu);}
.ebox.rosso{background:var(--rosso);}
.ebox.gray{background:var(--testo-3);}
.eday{font-size:19px;font-weight:700;line-height:1;}
.emon{font-size:9px;font-weight:600;letter-spacing:.06em;text-transform:uppercase;}
.einfo{flex:1;min-width:0;}
.etitle{font-size:13px;font-weight:600;color:var(--testo);line-height:1.3;margin-bottom:2px;}
.emeta{font-size:11px;color:var(--testo-3);}
.earrow{color:var(--border);font-size:18px;align-self:center;flex-shrink:0;}

/* ===================================================
   BADGES / PILLS
=================================================== */
.badge{
  display:inline-block;font-size:10px;font-weight:700;
  padding:2px 8px;border-radius:20px;
}
.badge.blu{background:var(--blu-light);color:var(--blu);}
.badge.rosso{background:var(--rosso-light);color:var(--rosso);}
.badge.verde{background:var(--verde-light);color:var(--verde);}
.badge.amber{background:var(--amber-light);color:var(--amber);}
.badge.gray{background:var(--bg);color:var(--testo-3);border:1px solid var(--border);}

/* ===================================================
   INFO BOXES
=================================================== */
.infobox{
  margin:0 14px 10px;border-radius:var(--r-sm);
  padding:11px 13px;display:flex;gap:10px;align-items:flex-start;
}
.infobox.warn{background:var(--amber-light);border-left:3px solid #e09020;}
.infobox.info{background:var(--blu-light);border-left:3px solid var(--blu);}
.infobox.ok{background:var(--verde-light);border-left:3px solid #27a96c;}
.infobox-icon{font-size:17px;flex-shrink:0;margin-top:1px;}
.infobox-lbl{font-size:10px;font-weight:800;letter-spacing:.05em;text-transform:uppercase;margin-bottom:2px;}
.infobox-lbl.amber{color:var(--amber);}
.infobox-lbl.blu{color:var(--blu);}
.infobox-lbl.verde{color:var(--verde);}
.infobox-text{font-size:12px;color:var(--testo);line-height:1.5;}

/* ===================================================
   QA GRID
=================================================== */
.qa-grid{
  display:grid;grid-template-columns:repeat(4,1fr);
  gap:8px;padding:14px 14px 4px;
}
.qa{display:flex;flex-direction:column;align-items:center;gap:5px;cursor:pointer;}
.qa-ico{
  width:54px;height:54px;border-radius:16px;
  display:flex;align-items:center;justify-content:center;
  font-size:24px;transition:transform .1s;
}
.qa:active .qa-ico{transform:scale(.93);}
.qa-ico.c1{background:var(--blu-light);}
.qa-ico.c2{background:var(--rosso-light);}
.qa-ico.c3{background:var(--verde-light);}
.qa-ico.c4{background:var(--amber-light);}
.qa-lbl{font-size:11px;color:var(--testo-2);font-weight:500;text-align:center;line-height:1.2;}

/* ===================================================
   HORIZONTAL SCROLL ROW
=================================================== */
.hrow{
  display:flex;gap:10px;overflow-x:auto;
  padding:0 14px 8px;scrollbar-width:none;
  -webkit-overflow-scrolling:touch;
}
.hrow::-webkit-scrollbar{display:none;}

/* ===================================================
   SERVICE TABLES
=================================================== */
.srv-section{margin:0 14px 10px;background:var(--white);border-radius:var(--r);box-shadow:var(--shadow);overflow:hidden;}
.srv-head{background:var(--bg);padding:9px 13px;display:flex;align-items:center;gap:7px;}
.srv-head .ico{font-size:17px;}
.srv-head .lbl{font-size:13px;font-weight:700;color:var(--testo);}
.srv-row{
  display:flex;justify-content:space-between;align-items:center;
  padding:9px 13px;border-bottom:1px solid var(--border);
}
.srv-row:last-child{border:none;}
.srv-name{font-size:12px;color:var(--testo);flex:1;padding-right:8px;}
.srv-val{font-size:12px;font-weight:600;color:var(--testo-2);text-align:right;white-space:nowrap;}
.srv-val.blu{color:var(--blu);}
.srv-val.verde{color:var(--verde);}

/* ===================================================
   TRASPARENZA
=================================================== */
.tcard{background:var(--white);border-radius:var(--r);box-shadow:var(--shadow);margin:0 14px 10px;overflow:hidden;}
.tcard-head{display:flex;justify-content:space-between;align-items:center;padding:13px 14px;border-bottom:1px solid var(--border);}
.tcard-title{font-size:13px;font-weight:700;color:var(--testo);}
.tcard-body{padding:10px 14px;}
.p-row{display:flex;align-items:center;gap:9px;padding:7px 0;border-bottom:1px solid var(--border);}
.p-row:last-child{border:none;}
.p-dot{width:9px;height:9px;border-radius:50%;flex-shrink:0;}
.p-dot.done{background:#27a96c;}
.p-dot.progress{background:#4a9eda;}
.p-dot.pending{background:#e09020;}
.p-text{font-size:12px;color:var(--testo);flex:1;line-height:1.35;}
.p-badge{font-size:9px;font-weight:700;padding:2px 7px;border-radius:20px;white-space:nowrap;}
.p-badge.done{background:var(--verde-light);color:var(--verde);}
.p-badge.progress{background:var(--blu-light);color:var(--blu);}
.p-badge.pending{background:var(--amber-light);color:var(--amber);}

/* ===================================================
   NOTIFICHE
=================================================== */
.notif-item{
  display:flex;gap:11px;padding:13px 14px;
  border-bottom:1px solid var(--border);cursor:pointer;
}
.notif-item.unread{background:#f0f4ff;}
.notif-ico{width:38px;height:38px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:17px;flex-shrink:0;}
.notif-ico.blu{background:var(--blu-light);}
.notif-ico.rosso{background:var(--rosso-light);}
.notif-ico.verde{background:var(--verde-light);}
.notif-body{flex:1;min-width:0;}
.notif-title{font-size:13px;font-weight:600;color:var(--testo);margin-bottom:1px;}
.notif-sub{font-size:11px;color:var(--testo-3);line-height:1.4;}
.notif-right{display:flex;flex-direction:column;align-items:flex-end;gap:5px;flex-shrink:0;}
.notif-time{font-size:10px;color:var(--testo-3);}
.unread-dot{width:7px;height:7px;border-radius:50%;background:var(--blu);}

/* ===================================================
   ADMIN PANEL
=================================================== */
.admin-top{
  background:linear-gradient(135deg,#0a1a50 0%,var(--blu) 100%);
  padding:16px 18px 18px;color:#fff;flex-shrink:0;
}
.admin-top h2{font-family:'Bebas Neue',sans-serif;font-size:22px;letter-spacing:.06em;}
.admin-top p{font-size:12px;opacity:.72;margin-top:2px;}
.admin-badge{
  display:inline-flex;align-items:center;gap:5px;
  background:rgba(255,255,255,.15);border-radius:20px;
  padding:3px 10px;font-size:11px;font-weight:600;margin-top:8px;
}
.tabs{display:flex;background:var(--white);border-bottom:1px solid var(--border);flex-shrink:0;}
.tab{
  flex:1;padding:11px 6px;text-align:center;
  font-size:12px;font-weight:600;color:var(--testo-3);
  cursor:pointer;border-bottom:2px solid transparent;transition:all .15s;
}
.tab.active{color:var(--blu);border-bottom-color:var(--blu);}
.admin-sc{flex:1;overflow-y:auto;-webkit-overflow-scrolling:touch;scrollbar-width:none;}
.admin-sc::-webkit-scrollbar{display:none;}

/* FORMS */
.form-card{background:var(--white);border-radius:var(--r);box-shadow:var(--shadow);margin:12px 14px;padding:16px;}
.form-card-title{font-size:14px;font-weight:700;color:var(--testo);margin-bottom:13px;}
.flabel{font-size:11px;font-weight:700;color:var(--testo-2);letter-spacing:.04em;text-transform:uppercase;margin-bottom:4px;display:block;}
.finput,.ftextarea,.fselect{
  width:100%;background:var(--bg);
  border:1.5px solid var(--border);border-radius:10px;
  padding:9px 11px;font-size:13px;color:var(--testo);
  font-family:'DM Sans',sans-serif;outline:none;
  transition:border-color .15s;margin-bottom:12px;
  -webkit-appearance:none;appearance:none;
}
.finput:focus,.ftextarea:focus,.fselect:focus{border-color:var(--blu);background:var(--white);}
.ftextarea{resize:none;height:75px;line-height:1.5;}
.frow{display:grid;grid-template-columns:1fr 1fr;gap:10px;}
.btn-primary{
  width:100%;background:var(--blu);color:#fff;border:none;
  border-radius:11px;padding:12px;font-size:14px;font-weight:700;
  font-family:'DM Sans',sans-serif;cursor:pointer;
  display:flex;align-items:center;justify-content:center;gap:6px;
  transition:opacity .15s;-webkit-appearance:none;
}
.btn-primary:active{opacity:.85;}
.btn-primary.rosso{background:var(--rosso);}
.btn-danger{
  background:var(--rosso-light);color:var(--rosso);border:none;
  border-radius:7px;padding:5px 10px;font-size:11px;font-weight:700;
  font-family:'DM Sans',sans-serif;cursor:pointer;
}
.admin-item{
  background:var(--white);border-radius:var(--r);box-shadow:var(--shadow);
  margin:0 14px 8px;padding:12px 14px;
  display:flex;gap:10px;align-items:flex-start;
}
.admin-item-ico{font-size:18px;flex-shrink:0;margin-top:2px;}
.admin-item-body{flex:1;min-width:0;}
.admin-item-title{font-size:13px;font-weight:700;color:var(--testo);margin-bottom:2px;}
.admin-item-meta{font-size:11px;color:var(--testo-3);}

/* ===================================================
   LOGIN OVERLAY
=================================================== */
#login-overlay{
  position:absolute;inset:0;
  background:linear-gradient(150deg,var(--blu-dark) 0%,var(--blu) 60%,#2456c0 100%);
  display:none;flex-direction:column;align-items:center;justify-content:center;
  z-index:100;padding:32px 24px;
}
.login-logo{font-family:'Bebas Neue',sans-serif;font-size:30px;color:#fff;letter-spacing:.08em;text-align:center;}
.login-sub{font-family:'Dancing Script',cursive;font-size:20px;color:#ff9090;text-align:center;margin-bottom:28px;}
.login-lbl{font-size:11px;font-weight:700;color:rgba(255,255,255,.55);letter-spacing:.06em;text-transform:uppercase;display:block;margin-bottom:4px;width:100%;}
.login-input{
  width:100%;background:rgba(255,255,255,.12);
  border:1.5px solid rgba(255,255,255,.2);border-radius:11px;
  padding:11px 14px;font-size:14px;color:#fff;
  font-family:'DM Sans',sans-serif;outline:none;margin-bottom:10px;
  -webkit-appearance:none;
}
.login-input::placeholder{color:rgba(255,255,255,.45);}
.login-input:focus{border-color:rgba(255,255,255,.6);background:rgba(255,255,255,.18);}
.login-btn{
  width:100%;background:#fff;color:var(--blu);border:none;
  border-radius:11px;padding:13px;font-size:15px;font-weight:700;
  font-family:'DM Sans',sans-serif;cursor:pointer;margin-top:4px;
  -webkit-appearance:none;
}
.login-btn:active{opacity:.9;}
.login-hint{font-size:11px;color:rgba(255,255,255,.4);text-align:center;margin-top:10px;}
.login-error{font-size:12px;color:#ff9090;text-align:center;margin-bottom:8px;display:none;}

/* ===================================================
   DETAIL OVERLAY
=================================================== */
.detail-overlay{
  position:absolute;inset:0;background:var(--white);
  z-index:50;display:none;flex-direction:column;overflow:hidden;
}
.detail-overlay.open{display:flex;animation:fadeUp .2s ease;}
.detail-head{
  padding:12px 16px;display:flex;align-items:center;gap:10px;
  border-bottom:1px solid var(--border);flex-shrink:0;
  padding-top:calc(12px + var(--safe-top));
  background:var(--white);
}
.detail-back{font-size:24px;cursor:pointer;color:var(--testo-2);line-height:1;}
.detail-head-title{font-size:14px;font-weight:700;color:var(--testo);flex:1;}
.detail-body{flex:1;overflow-y:auto;padding:20px 16px;-webkit-overflow-scrolling:touch;}
.detail-tag{font-size:10px;font-weight:700;letter-spacing:.06em;text-transform:uppercase;color:var(--blu);margin-bottom:7px;}
.detail-title{font-size:20px;font-weight:700;color:var(--testo);line-height:1.3;margin-bottom:10px;}
.detail-meta{display:flex;flex-wrap:wrap;gap:5px;margin-bottom:14px;}
.detail-text{font-size:14px;color:var(--testo-2);line-height:1.75;white-space:pre-line;}

/* ===================================================
   TOAST
=================================================== */
#toast{
  position:absolute;
  bottom:calc(70px + var(--safe-bottom));
  left:50%;transform:translateX(-50%) translateY(8px);
  background:rgba(14,22,50,.9);color:#fff;
  padding:9px 18px;border-radius:22px;
  font-size:13px;white-space:nowrap;
  opacity:0;transition:all .25s;z-index:300;pointer-events:none;
  backdrop-filter:blur(8px);-webkit-backdrop-filter:blur(8px);
  max-width:calc(100% - 40px);white-space:normal;text-align:center;
}

/* ===================================================
   SPACERS & UTILS
=================================================== */
.pb-safe{height:calc(16px + var(--safe-bottom));}
.section-lbl{
  font-size:11px;font-weight:700;color:var(--testo-3);
  text-transform:uppercase;letter-spacing:.06em;
  padding:12px 14px 6px;
}
.divider{height:1px;background:var(--border);margin:4px 0;}

/* ===================================================
   PROFILO / SETTINGS ROWS
=================================================== */
.set-card{background:var(--white);border-radius:var(--r);box-shadow:var(--shadow);margin:0 14px 10px;overflow:hidden;}
.set-row{
  display:flex;align-items:center;gap:12px;
  padding:13px 14px;border-bottom:1px solid var(--border);
  cursor:pointer;
}
.set-row:last-child{border:none;}
.set-ico{font-size:19px;width:28px;text-align:center;flex-shrink:0;}
.set-lbl{flex:1;font-size:13px;color:var(--testo);}
.set-val{font-size:12px;color:var(--testo-3);}
.set-arr{font-size:18px;color:var(--border);}

/* ===================================================
   STATS GRID
=================================================== */
.stats-grid{
  display:grid;grid-template-columns:repeat(3,1fr);
  gap:8px;margin:0 14px 10px;
}
.stat-box{
  background:var(--white);border-radius:var(--r-sm);
  box-shadow:var(--shadow);padding:11px;text-align:center;
}
.stat-num{font-size:22px;font-weight:700;}
.stat-num.verde{color:var(--verde);}
.stat-num.blu{color:var(--blu);}
.stat-num.amber{color:var(--amber);}
.stat-lbl{font-size:10px;color:var(--testo-3);font-weight:600;margin-top:1px;}

/* ===================================================
   RESPONSIVE — tablet e desktop centrati
=================================================== */
@media(min-width:480px){
  body{background:#C8282A;}
  #app{
    margin:0 auto;
    border-radius:0;
    height:100vh;
    max-height:100vh;
  }
}

/* ===================================================
   HOME BANNER — bianco/blu diagonale
=================================================== */
.home-banner{
  position:relative;
  background:#fff;
  overflow:hidden;
  min-height:200px;
  flex-shrink:0;
}

/* triangolo blu top-left */
.hb-blu-top{
  position:absolute;
  top:0; left:0;
  width:0; height:0;
  border-style:solid;
  border-width:180px 220px 0 0;
  border-color:#1A3F8F transparent transparent transparent;
}

/* triangolo blu bottom-right */
.hb-blu-bottom{
  position:absolute;
  bottom:0; right:0;
  width:0; height:0;
  border-style:solid;
  border-width:0 0 70px 260px;
  border-color:transparent transparent #1A3F8F transparent;
}

.hb-content{
  position:relative;
  z-index:2;
  padding:calc(var(--safe-top) + 14px) 18px 14px;
}

.hb-site{
  font-size:12px;
  font-weight:700;
  color:#fff;
  letter-spacing:.02em;
  margin-bottom:14px;
  text-shadow:0 1px 3px rgba(0,0,0,.25);
}

.hb-pills{
  display:flex;flex-wrap:wrap;gap:6px;
  margin-top:14px;
}
.hb-pill{
  font-size:10px;font-weight:700;
  padding:3px 10px;border-radius:20px;
  background:rgba(26,63,143,.15);color:var(--blu);
  border:1px solid rgba(26,63,143,.2);
}
.hb-pill.red{
  background:rgba(200,40,42,.1);color:var(--rosso);
  border-color:rgba(200,40,42,.2);
}

/* ===================================================
   LOGO SWITCHER (solo preview)
=================================================== */
.logo-switcher{
  position:absolute;bottom:10px;right:12px;
  display:flex;align-items:center;gap:4px;z-index:10;
}
.ls-btn{
  width:22px;height:22px;border-radius:6px;
  background:rgba(255,255,255,.25);border:1px solid rgba(255,255,255,.4);
  color:#fff;font-size:11px;font-weight:700;cursor:pointer;
  font-family:'DM Sans',sans-serif;
  transition:background .15s;
}
.ls-btn.active{background:var(--blu);border-color:var(--blu);}
.ls-btn:hover{background:rgba(255,255,255,.5);color:var(--testo);}

/* ===================================================
   LOGO OPZIONE 1: Bold block con barre tricolore
   VMA grande impilato, barre blu/rosso laterali
=================================================== */
.vma-opt{display:flex;align-items:center;gap:12px;}

.vma1-wrap{
  display:flex;align-items:center;gap:5px;
  flex-shrink:0;
}
.vma1-bar{
  width:4px;border-radius:2px;height:48px;
}
.vma1-bar.blu{background:var(--blu);}
.vma1-bar.rosso{background:var(--rosso);}

.vma1-letters{
  display:flex;gap:1px;line-height:1;
}
.vma1-v,.vma1-m,.vma1-a{
  font-family:'Bebas Neue',sans-serif;
  font-size:46px;
  letter-spacing:-.01em;
  line-height:1;
}
.vma1-v{color:var(--blu);}
.vma1-m{color:var(--testo);}
.vma1-a{color:var(--rosso);}

.vma1-text{
  display:flex;flex-direction:column;justify-content:center;
}
.vma1-viareggio{
  font-family:'Bebas Neue',sans-serif;
  font-size:18px;letter-spacing:.12em;
  color:var(--testo);line-height:1;
}
.vma1-monamour{
  font-family:'Dancing Script',cursive;
  font-size:17px;color:var(--rosso);
  line-height:1.2;
}

/* ===================================================
   LOGO OPZIONE 2: Tre bande diagonali V | M | A
=================================================== */
.vma2-band-wrap{
  display:flex;height:50px;overflow:hidden;
  border-radius:8px;flex-shrink:0;
  clip-path:polygon(6% 0%, 100% 0%, 94% 100%, 0% 100%);
}
.vma2-band{
  display:flex;align-items:center;justify-content:center;
  flex:1;font-family:'Bebas Neue',sans-serif;
  font-size:30px;font-weight:400;
}
.vma2-band.b1{background:var(--blu);color:#fff;}
.vma2-band.b2{background:#fff;color:var(--testo);}
.vma2-band.b3{background:var(--rosso);color:#fff;}

.vma2-sub{
  display:flex;flex-direction:column;justify-content:center;
  margin-left:10px;
}
.vma2-viareggio{
  font-family:'Bebas Neue',sans-serif;
  font-size:18px;letter-spacing:.12em;
  color:var(--testo);line-height:1;
}
.vma2-monamour{
  font-family:'Dancing Script',cursive;
  font-size:17px;color:var(--rosso);line-height:1.2;
}

/* ===================================================
   LOGO OPZIONE 3: Cerchio con VMA + testo affiancato
=================================================== */
.vma3-circle{
  width:56px;height:56px;border-radius:50%;
  background:linear-gradient(135deg,var(--blu) 0%,var(--blu) 40%,#fff 40%,#fff 60%,var(--rosso) 60%);
  display:flex;align-items:center;justify-content:center;
  flex-shrink:0;
  box-shadow:0 2px 8px rgba(0,0,0,.15);
  border:2px solid rgba(255,255,255,.6);
}
.vma3-letters{
  font-family:'Bebas Neue',sans-serif;
  font-size:20px;letter-spacing:.06em;
  color:#fff;
  text-shadow:0 1px 3px rgba(0,0,0,.4);
}
.vma3-text{
  display:flex;flex-direction:column;justify-content:center;
  margin-left:12px;
}
.vma3-viareggio{
  font-family:'Bebas Neue',sans-serif;
  font-size:20px;letter-spacing:.12em;
  color:var(--testo);line-height:1;
}
.vma3-monamour{
  font-family:'Dancing Script',cursive;
  font-size:18px;color:var(--rosso);line-height:1.2;
}

</style>
</head>
<body>

<div id="app">

  <!-- ===================== HOME ===================== -->
  <div class="screen active" id="screen-home">
    <div class="sc">

      <!-- ===== BANNER HOME: bianco/blu diagonale stile immagine ===== -->
      <div class="home-banner safe-top">

        <!-- Striscia blu in alto a sinistra (triangolo) -->
        <div class="hb-blu-top"></div>
        <!-- Striscia blu in basso a destra -->
        <div class="hb-blu-bottom"></div>

        <!-- Contenuto del banner -->
        <div class="hb-content">
          <!-- sito marialina.it in alto a sinistra -->
          <div class="hb-site">marialina.it</div>

          <!-- LOGO — opzione selezionata (default: opzione 1) -->
          <!-- Per cambiare logo: imposta display:flex su una sola opzione e display:none sulle altre -->

          <!-- OPZIONE 1: Bold block — VMA impilato con barre colore -->
          <div class="vma-opt vma-opt1" id="logo-opt1">
            <div class="vma1-wrap">
              <div class="vma1-bar blu"></div>
              <div class="vma1-letters">
                <span class="vma1-v">V</span><span class="vma1-m">M</span><span class="vma1-a">A</span>
              </div>
              <div class="vma1-bar rosso"></div>
            </div>
            <div class="vma1-text">
              <span class="vma1-viareggio">VIAREGGIO</span>
              <span class="vma1-monamour">mon Amour</span>
            </div>
          </div>

          <!-- OPZIONE 2: Diagonal split — V|M|A su tre bande diagonali -->
          <div class="vma-opt vma-opt2" id="logo-opt2" style="display:none;">
            <div class="vma2-band-wrap">
              <div class="vma2-band b1"><span>V</span></div>
              <div class="vma2-band b2"><span>M</span></div>
              <div class="vma2-band b3"><span>A</span></div>
            </div>
            <div class="vma2-sub">
              <span class="vma2-viareggio">VIAREGGIO</span>
              <span class="vma2-monamour">mon Amour</span>
            </div>
          </div>

          <!-- OPZIONE 3: Minimal circle — VMA in cerchio con scritta intorno -->
          <div class="vma-opt vma-opt3" id="logo-opt3" style="display:none;">
            <div class="vma3-circle">
              <span class="vma3-letters">VMA</span>
            </div>
            <div class="vma3-text">
              <span class="vma3-viareggio">VIAREGGIO</span>
              <span class="vma3-monamour">mon Amour</span>
            </div>
          </div>

          <!-- Pill data voto -->
          <div class="hb-pills">
            <span class="hb-pill">📅 Voto: 15 Giu 2026</span>
            <span class="hb-pill red">🔴 Campagna attiva</span>
          </div>
        </div>

        <!-- Selettore logo (solo per preview — rimuovere in produzione) -->
        <div class="logo-switcher">
          <span style="font-size:10px;font-weight:700;color:rgba(255,255,255,.5);text-transform:uppercase;letter-spacing:.06em;margin-right:6px;">Logo:</span>
          <button class="ls-btn active" onclick="switchLogo(1)">1</button>
          <button class="ls-btn" onclick="switchLogo(2)">2</button>
          <button class="ls-btn" onclick="switchLogo(3)">3</button>
        </div>
      </div>
      <!-- fine banner -->

      <div class="tri"></div>

      <!-- QUICK ACTIONS -->
      <div class="qa-grid">
        <div class="qa" onclick="switchScreen('notizie')">
          <div class="qa-ico c1">📰</div>
          <span class="qa-lbl">Notizie</span>
        </div>
        <div class="qa" onclick="switchScreen('eventi')">
          <div class="qa-ico c2">🗓️</div>
          <span class="qa-lbl">Eventi</span>
        </div>
        <div class="qa" onclick="switchScreen('trasparenza')">
          <div class="qa-ico c3">📊</div>
          <span class="qa-lbl">Trasparenza</span>
        </div>
        <div class="qa" onclick="switchScreen('servizi')">
          <div class="qa-ico c4">🚌</div>
          <span class="qa-lbl">Servizi</span>
        </div>
      </div>

      <!-- REMINDER -->
      <div class="infobox warn" style="margin-top:4px;">
        <span class="infobox-icon">🔔</span>
        <div>
          <div class="infobox-lbl amber">Reminder</div>
          <div class="infobox-text">Comizio in Piazza Mazzini <b>domenica 29 marzo ore 17:30</b></div>
        </div>
      </div>

      <!-- ULTIME NOTIZIE -->
      <div class="stitle">Ultime notizie <a onclick="switchScreen('notizie')">Tutte →</a></div>

      <div class="card" onclick="openDetail('news','n1')">
        <div class="card-body">
          <div class="card-tag">Programma</div>
          <div class="card-title">Piano mare: riqualificazione del Lungomare</div>
          <div class="card-desc">Più verde, più accessibile, più sicuro: il progetto per il cuore di Viareggio.</div>
          <div class="card-meta">📅 20 mar 2026 · <span class="badge blu">Programma</span></div>
        </div>
      </div>
      <div class="card" onclick="openDetail('news','n2')">
        <div class="card-body">
          <div class="card-tag rosso">Campagna</div>
          <div class="card-title">Incontro con i cittadini del quartiere Migliarina</div>
          <div class="card-desc">80 cittadini, proposte concrete. Rivedi il resoconto dell'incontro del 18 marzo.</div>
          <div class="card-meta">📅 18 mar 2026 · <span class="badge rosso">Incontro</span></div>
        </div>
      </div>

      <!-- PROSSIMI EVENTI -->
      <div class="stitle">Prossimi eventi <a onclick="switchScreen('eventi')">Tutti →</a></div>
      <div class="ecard" onclick="openDetail('event','e1')">
        <div class="ebox rosso"><div class="eday">29</div><div class="emon">MAR</div></div>
        <div class="einfo">
          <div class="etitle">Comizio — Piazza Mazzini</div>
          <div class="emeta">📍 P.za Mazzini • ore 17:30</div>
        </div>
        <div class="earrow">›</div>
      </div>
      <div class="ecard" onclick="openDetail('event','e2')">
        <div class="ebox blu"><div class="eday">05</div><div class="emon">APR</div></div>
        <div class="einfo">
          <div class="etitle">Tavola rotonda — Il futuro del porto</div>
          <div class="emeta">📍 Camera di Commercio • ore 10:00</div>
        </div>
        <div class="earrow">›</div>
      </div>

      <div class="pb-safe"></div>
    </div>
    <div class="bnav">
      <div class="ni active" onclick="switchScreen('home')"><span class="nicon">🏠</span><span class="nlabel">Home</span></div>
      <div class="ni" onclick="switchScreen('notizie')"><span class="nicon">📰</span><span class="nlabel">Notizie</span></div>
      <div class="ni" onclick="switchScreen('notifiche')">
        <div class="ni-wrap"><span class="nicon">🔔</span><span class="notif-dot"></span></div>
        <span class="nlabel">Notifiche</span>
      </div>
      <div class="ni" onclick="switchScreen('servizi')"><span class="nicon">🚌</span><span class="nlabel">Servizi</span></div>
      <div class="ni" onclick="switchScreen('profilo')"><span class="nicon">👤</span><span class="nlabel">Profilo</span></div>
    </div>
  </div>

  <!-- ===================== NOTIZIE ===================== -->
  <div class="screen" id="screen-notizie">
    <div class="ph blu-grad safe-top">
      <div class="ph-title">Notizie</div>
      <div class="ph-sub">Aggiornamenti dalla campagna</div>
      <span class="ph-icon">📰</span>
    </div>
    <div class="tri"></div>
    <div class="sc">
      <div class="hrow" style="padding-top:12px;">
        <span class="badge blu" style="cursor:pointer;padding:6px 13px;font-size:11px;">Tutte</span>
        <span class="badge gray" style="cursor:pointer;padding:6px 13px;font-size:11px;">Programma</span>
        <span class="badge gray" style="cursor:pointer;padding:6px 13px;font-size:11px;">Campagna</span>
        <span class="badge gray" style="cursor:pointer;padding:6px 13px;font-size:11px;">Comune</span>
        <span class="badge gray" style="cursor:pointer;padding:6px 13px;font-size:11px;">Avviso</span>
      </div>
      <div id="news-list" style="padding-top:4px;">
        <div class="card" onclick="openDetail('news','n1')">
          <div class="card-body">
            <div class="card-tag">Programma</div>
            <div class="card-title">Piano mare: riqualificazione del Lungomare</div>
            <div class="card-desc">Più verde, più accessibile, più sicuro: il nostro progetto per il cuore di Viareggio.</div>
            <div class="card-meta">📅 20 mar 2026 · <span class="badge blu">Programma</span></div>
          </div>
        </div>
        <div class="card" onclick="openDetail('news','n2')">
          <div class="card-body">
            <div class="card-tag rosso">Campagna</div>
            <div class="card-title">Incontro con i cittadini del quartiere Migliarina</div>
            <div class="card-desc">Ascolto diretto, proposte concrete. Rivedi il resoconto dell'incontro.</div>
            <div class="card-meta">📅 18 mar 2026 · <span class="badge rosso">Incontro</span></div>
          </div>
        </div>
        <div class="card" onclick="openDetail('news','n3')">
          <div class="card-body">
            <div class="card-tag amber">Avviso</div>
            <div class="card-title">Dal 3 agosto: carta d'identità cartacea non più valida</div>
            <div class="card-desc">Il regolamento europeo 2025/1208 impone il rinnovo entro agosto 2026.</div>
            <div class="card-meta">📅 15 mar 2026 · <span class="badge amber">Avviso</span></div>
          </div>
        </div>
        <div class="card" onclick="openDetail('news','n4')">
          <div class="card-body">
            <div class="card-tag">Programma</div>
            <div class="card-title">Scuole: il nostro piano per l'edilizia scolastica</div>
            <div class="card-desc">Sicurezza, efficienza energetica e ambienti moderni per i ragazzi.</div>
            <div class="card-meta">📅 10 mar 2026 · <span class="badge blu">Programma</span></div>
          </div>
        </div>
      </div>
      <div class="pb-safe"></div>
    </div>
    <div class="bnav">
      <div class="ni" onclick="switchScreen('home')"><span class="nicon">🏠</span><span class="nlabel">Home</span></div>
      <div class="ni active" onclick="switchScreen('notizie')"><span class="nicon">📰</span><span class="nlabel">Notizie</span></div>
      <div class="ni" onclick="switchScreen('notifiche')"><div class="ni-wrap"><span class="nicon">🔔</span><span class="notif-dot"></span></div><span class="nlabel">Notifiche</span></div>
      <div class="ni" onclick="switchScreen('servizi')"><span class="nicon">🚌</span><span class="nlabel">Servizi</span></div>
      <div class="ni" onclick="switchScreen('profilo')"><span class="nicon">👤</span><span class="nlabel">Profilo</span></div>
    </div>
  </div>

  <!-- ===================== EVENTI ===================== -->
  <div class="screen" id="screen-eventi">
    <div class="ph rosso-grad safe-top">
      <div class="ph-title">Eventi</div>
      <div class="ph-sub">Calendario della campagna</div>
      <span class="ph-icon">🗓️</span>
    </div>
    <div class="tri"></div>
    <div class="sc">
      <div class="section-lbl" style="padding-top:14px;">Prossimi</div>
      <div id="eventi-list">
        <div class="ecard" onclick="openDetail('event','e1')">
          <div class="ebox rosso"><div class="eday">29</div><div class="emon">MAR</div></div>
          <div class="einfo"><div class="etitle">Comizio — Piazza Mazzini</div><div class="emeta">📍 P.za Mazzini • ore 17:30</div><div style="margin-top:4px;"><span class="badge rosso">Comizio</span></div></div>
          <div class="earrow">›</div>
        </div>
        <div class="ecard" onclick="openDetail('event','e2')">
          <div class="ebox blu"><div class="eday">05</div><div class="emon">APR</div></div>
          <div class="einfo"><div class="etitle">Tavola rotonda — Il futuro del porto</div><div class="emeta">📍 Camera di Commercio • ore 10:00</div><div style="margin-top:4px;"><span class="badge blu">Dibattito</span></div></div>
          <div class="earrow">›</div>
        </div>
        <div class="ecard" onclick="openDetail('event','e3')">
          <div class="ebox rosso"><div class="eday">12</div><div class="emon">APR</div></div>
          <div class="einfo"><div class="etitle">Gazebo — Quartiere Darsena</div><div class="emeta">📍 P.za della Libertà • ore 10:00–13:00</div><div style="margin-top:4px;"><span class="badge rosso">Gazebo</span></div></div>
          <div class="earrow">›</div>
        </div>
        <div class="ecard" onclick="openDetail('event','e4')">
          <div class="ebox blu"><div class="eday">20</div><div class="emon">APR</div></div>
          <div class="einfo"><div class="etitle">Presentazione programma completo</div><div class="emeta">📍 Teatro Politeama • ore 20:30</div><div style="margin-top:4px;"><span class="badge blu">Evento</span></div></div>
          <div class="earrow">›</div>
        </div>
      </div>
      <div class="section-lbl">Passati</div>
      <div class="ecard" style="opacity:.55;">
        <div class="ebox gray"><div class="eday">18</div><div class="emon">MAR</div></div>
        <div class="einfo"><div class="etitle">Incontro Migliarina</div><div class="emeta">📍 Oratorio Don Bosco • ore 18:30</div><div style="margin-top:4px;"><span class="badge gray">Concluso</span></div></div>
      </div>
      <div class="pb-safe"></div>
    </div>
    <div class="bnav">
      <div class="ni" onclick="switchScreen('home')"><span class="nicon">🏠</span><span class="nlabel">Home</span></div>
      <div class="ni" onclick="switchScreen('notizie')"><span class="nicon">📰</span><span class="nlabel">Notizie</span></div>
      <div class="ni" onclick="switchScreen('notifiche')"><div class="ni-wrap"><span class="nicon">🔔</span><span class="notif-dot"></span></div><span class="nlabel">Notifiche</span></div>
      <div class="ni" onclick="switchScreen('servizi')"><span class="nicon">🚌</span><span class="nlabel">Servizi</span></div>
      <div class="ni" onclick="switchScreen('profilo')"><span class="nicon">👤</span><span class="nlabel">Profilo</span></div>
    </div>
  </div>

  <!-- ===================== NOTIFICHE ===================== -->
  <div class="screen" id="screen-notifiche">
    <div class="ph blu-grad safe-top">
      <div class="ph-title">Notifiche</div>
      <div class="ph-sub">Aggiornamenti per te</div>
      <span class="ph-icon">🔔</span>
    </div>
    <div class="tri"></div>
    <div class="sc">
      <div style="display:flex;justify-content:space-between;align-items:center;padding:11px 14px 6px;">
        <span style="font-size:12px;font-weight:700;color:var(--testo-2);">Non lette <span style="background:var(--rosso);color:#fff;border-radius:20px;padding:1px 7px;font-size:10px;font-weight:700;">3</span></span>
        <span style="font-size:12px;color:var(--blu);cursor:pointer;font-weight:500;">Segna tutte lette</span>
      </div>
      <div style="background:var(--white);border-radius:var(--r);box-shadow:var(--shadow);margin:0 14px 10px;overflow:hidden;">
        <div class="notif-item unread">
          <div class="notif-ico rosso">🔔</div>
          <div class="notif-body"><div class="notif-title">Reminder: Comizio Piazza Mazzini</div><div class="notif-sub">Domenica 29 marzo ore 17:30 — porta amici!</div></div>
          <div class="notif-right"><div class="notif-time">Oggi</div><div class="unread-dot"></div></div>
        </div>
        <div class="notif-item unread">
          <div class="notif-ico blu">📰</div>
          <div class="notif-body"><div class="notif-title">Nuova notizia: Piano mare</div><div class="notif-sub">Pubblicato il progetto di riqualificazione del Lungomare</div></div>
          <div class="notif-right"><div class="notif-time">Ieri</div><div class="unread-dot"></div></div>
        </div>
        <div class="notif-item unread">
          <div class="notif-ico verde">📊</div>
