        <div><h2>Pannello Admin</h2><p>Gestione contenuti app</p></div>
        <button onclick="adminLogout()" style="background:rgba(255,255,255,.15);border:none;color:#fff;border-radius:9px;padding:6px 11px;font-size:12px;font-weight:600;cursor:pointer;font-family:'DM Sans',sans-serif;">Esci ›</button>
