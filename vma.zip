</div><!-- fine #app -->

<script data-cfasync="false" src="/cdn-cgi/scripts/5c5dd728/cloudflare-static/email-decode.min.js"></script><script>
// ── LOGO SWITCHER ────────────────────────────────────────
function switchLogo(n) {
  [1,2,3].forEach(i => {
    const el = document.getElementById('logo-opt'+i);
    if(el) el.style.display = (i===n) ? 'flex' : 'none';
  });
  document.querySelectorAll('.ls-btn').forEach((b,i) => {
    b.classList.toggle('active', i+1===n);
  });
}

// ── NAVIGATION ──────────────────────────────────────────
const ALL_SCREENS = ['home','notizie','eventi','notifiche','trasparenza','servizi','profilo','admin'];
function switchScreen(name) {
  ALL_SCREENS.forEach(s => {
    const el = document.getElementById('screen-'+s);
    if(el) el.classList.remove('active');
  });
  const t = document.getElementById('screen-'+name);
  if(t) t.classList.add('active');
  window.scrollTo(0,0);
}

// ── TOAST ────────────────────────────────────────────────
let toastTimer;
function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.style.opacity = '1';
  t.style.transform = 'translateX(-50%) translateY(0)';
  clearTimeout(toastTimer);
  toastTimer = setTimeout(()=>{
    t.style.opacity = '0';
    t.style.transform = 'translateX(-50%) translateY(8px)';
  }, 2800);
}

// ── LOGIN ────────────────────────────────────────────────
function showAdminLogin() {
  const ov = document.getElementById('login-overlay');
  ov.style.display = 'flex';
  document.getElementById('login-error').style.display = 'none';
  document.getElementById('login-email').value = '';
  document.getElementById('login-pwd').value = '';
  setTimeout(()=>document.getElementById('login-email').focus(), 300);
}
function hideAdminLogin() {
  document.getElementById('login-overlay').style.display = 'none';
}
function doLogin() {
  const email = document.getElementById('login-email').value.trim();
  const pwd = document.getElementById('login-pwd').value;
  if(email === 'admin@viareggio.it' && pwd === 'admin123') {
    hideAdminLogin();
    switchScreen('admin');
    showToast('✅ Benvenuto, amministratore');
  } else {
    document.getElementById('login-error').style.display = 'block';
  }
}
function adminLogout() {
  switchScreen('profilo');
  showToast('Uscito dall\'area admin');
}

// ── ADMIN TABS ───────────────────────────────────────────
function switchAdminTab(name, el) {
  ['events','news','push'].forEach(t => {
    document.getElementById('atab-'+t).style.display = 'none';
  });
  document.getElementById('atab-'+name).style.display = 'block';
  document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
  if(el) el.classList.add('active');
}

// ── ADD EVENT ────────────────────────────────────────────
let eventCount = 4;
function addEvent() {
  const title = document.getElementById('ev-title').value.trim();
  const place = document.getElementById('ev-place').value.trim();
  const date  = document.getElementById('ev-date').value;
  const time  = document.getElementById('ev-time').value;
  if(!title || !place || !date) { showToast('⚠️ Compila i campi obbligatori'); return; }
  eventCount++;
  document.getElementById('event-count').textContent = eventCount;
  const dateStr = new Date(date).toLocaleDateString('it-IT',{day:'2-digit',month:'short',year:'numeric'});
  // Admin list
  const adminEl = document.createElement('div');
  adminEl.className = 'admin-item';
  adminEl.innerHTML = `<span class="admin-item-ico">🗓️</span>
    <div class="admin-item-body">
      <div class="admin-item-title">${title}</div>
      <div class="admin-item-meta">📅 ${dateStr}${time?' • '+time:''} • ${place}</div>
    </div>
    <button class="btn-danger" onclick="showToast('Eliminato');this.closest('.admin-item').remove()">✕</button>`;
  document.getElementById('admin-events-list').prepend(adminEl);
  // Public list
  const d = new Date(date);
  const months = ['GEN','FEB','MAR','APR','MAG','GIU','LUG','AGO','SET','OTT','NOV','DIC'];
  const pubEl = document.createElement('div');
  pubEl.className = 'ecard';
  pubEl.innerHTML = `<div class="ebox rosso"><div class="eday">${String(d.getDate()).padStart(2,'0')}</div><div class="emon">${months[d.getMonth()]}</div></div>
    <div class="einfo"><div class="etitle">${title}</div><div class="emeta">📍 ${place}${time?' • ore '+time:''}</div></div>
    <div class="earrow">›</div>`;
  const list = document.getElementById('eventi-list');
  list.insertBefore(pubEl, list.firstChild);
  ['ev-title','ev-short','ev-long','ev-date','ev-time','ev-place'].forEach(id => document.getElementById(id).value = '');
  showToast('✅ Evento pubblicato!');
}

// ── ADD NEWS ─────────────────────────────────────────────
let newsCount = 4;
function addNews() {
  const title = document.getElementById('news-title').value.trim();
  const short = document.getElementById('news-short').value.trim();
  const cat   = document.getElementById('news-cat').value;
  const push  = document.getElementById('news-push').value.includes('Sì');
  if(!title) { showToast('⚠️ Inserisci un titolo'); return; }
  newsCount++;
  document.getElementById('news-count').textContent = newsCount;
  // Admin
  const adminEl = document.createElement('div');
  adminEl.className = 'admin-item';
  adminEl.innerHTML = `<span class="admin-item-ico">📰</span>
    <div class="admin-item-body">
      <div class="admin-item-title">${title}</div>
      <div class="admin-item-meta">📅 Oggi · ${cat}</div>
    </div>
    <button class="btn-danger" onclick="showToast('Eliminato');this.closest('.admin-item').remove()">✕</button>`;
  document.getElementById('admin-news-list').prepend(adminEl);
  // Public
  const pubEl = document.createElement('div');
  pubEl.className = 'card';
  pubEl.innerHTML = `<div class="card-body">
    <div class="card-tag">${cat}</div>
    <div class="card-title">${title}</div>
    ${short?`<div class="card-desc">${short}</div>`:''}
    <div class="card-meta">📅 Oggi · <span class="badge blu">${cat}</span></div>
  </div>`;
  document.getElementById('news-list').prepend(pubEl);
  ['news-title','news-short','news-long'].forEach(id => document.getElementById(id).value = '');
  showToast(push ? '✅ Notizia pubblicata e notifica inviata!' : '✅ Notizia pubblicata');
}

// ── PUSH ─────────────────────────────────────────────────
function sendPush() {
  const t = document.getElementById('push-title').value.trim();
  const b = document.getElementById('push-body').value.trim();
  if(!t||!b) { showToast('⚠️ Compila titolo e messaggio'); return; }
  document.getElementById('push-title').value = '';
  document.getElementById('push-body').value = '';
  showToast('🔔 Notifica inviata a tutti gli utenti!');
}

// ── DETAIL OVERLAY ───────────────────────────────────────
const DETAIL_DATA = {
  news: {
    n1:{tag:'Programma',title:'Piano mare: riqualificazione del Lungomare',meta:['📅 20 marzo 2026','🏷️ Programma'],text:'Il nostro piano prevede la completa riqualificazione del Lungomare di Viareggio. Più verde, più accessibile, più sicuro.\n\nNel dettaglio:\n• Nuova pavimentazione antiscivolo e accessibile ai disabili\n• Piste ciclabili protette per tutto il lungomare\n• 40 nuovi alberi e 200 nuove piante\n• Illuminazione a LED a basso consumo\n• Nuovi spazi giochi per bambini\n• Wi-Fi gratuito nelle aree pubbliche\n\nL\'intervento è finanziato con fondi PNRR per un totale di €4,2 milioni.'},
    n2:{tag:'Campagna',title:'Incontro con i cittadini del quartiere Migliarina',meta:['📅 18 marzo 2026','📍 Oratorio Don Bosco'],text:'Un incontro partecipato e ricco di proposte. Oltre 80 cittadini hanno partecipato all\'incontro di ascolto nel quartiere Migliarina.\n\nI temi principali emersi:\n• Necessità di nuovi marciapiedi su Via Aurelia\n• Potenziamento della linea bus n.2\n• Richiesta di un nuovo parco giochi\n• Sicurezza stradale davanti alle scuole\n\nTutte le proposte verranno inserite nel programma elettorale.'},
    n3:{tag:'Avviso',title:"Dal 3 agosto 2026: carta d'identità cartacea non più valida",meta:['📅 15 marzo 2026','⚠️ Avviso importante'],text:"Il Regolamento Europeo 2025/1208 stabilisce che dal 3 agosto 2026 la carta d'identità cartacea non sarà più valida indipendentemente dalla data di scadenza.\n\nCosa fare:\n• Prenotare online su servizi.comune.viareggio.lu.it\n• Portare una foto tessera e il vecchio documento\n• Il costo è di €22,50\n\nSportello anagrafe: Lun-Ven 8:30-12:30, Lun e Mer anche 15:00-17:00."},
    n4:{tag:'Programma',title:"Scuole: il nostro piano per l'edilizia scolastica",meta:['📅 10 marzo 2026'],text:'La sicurezza e la qualità degli spazi educativi è priorità assoluta.\n\nIl piano prevede:\n• Messa in sicurezza di tutti gli edifici scolastici entro il 2027\n• Cappotti termici ed efficienza energetica (risparmio: 40%)\n• Nuova mensa per la scuola primaria Migliarina\n• Ambienti digitali e laboratori per le scuole secondarie\n\nBudget previsto: €6,8 milioni (di cui €4M da fondi PNRR).'}
  },
  event: {
    e1:{tag:'Comizio',title:'Comizio — Piazza Mazzini',meta:['📅 Domenica 29 marzo 2026','🕐 Ore 17:30','📍 Piazza Mazzini, Viareggio','🎟️ Ingresso libero'],text:'Il grande comizio di presentazione della candidatura!\n\nPorta amici, parenti e vicini di casa. Insieme possiamo fare la differenza.\n\nProgramma della serata:\n• 17:30 — Apertura con musica dal vivo\n• 18:00 — Interventi dei sostenitori\n• 18:30 — Discorso della candidata\n• 19:30 — Brindisi e aperitivo popolare\n\nParcheggio consigliato: Stadio dei Pini (gratuito, 10 min a piedi).'},
    e2:{tag:'Dibattito',title:'Tavola rotonda — Il futuro del porto di Viareggio',meta:['📅 Domenica 5 aprile 2026','🕐 Ore 10:00','📍 Camera di Commercio'],text:'Una mattinata di confronto sul futuro del porto.\n\nRelatori invitati:\n• Autorità Portuale Toscana\n• Associazione Cantieristica Nautica\n• Rappresentanti delle categorie lavorative\n\nIl porto di Viareggio è il secondo polo della cantieristica nautica italiana. Il nostro programma prevede €12 milioni di investimenti e 200 nuovi posti di lavoro.'},
    e3:{tag:'Gazebo',title:'Gazebo — Quartiere Darsena',meta:['📅 Domenica 12 aprile 2026','🕐 Ore 10:00–13:00','📍 Piazza della Libertà'],text:'Vieni a trovarci al gazebo!\n\nSaremo presenti per ascoltare le tue proposte e presentare il programma per questo quartiere.\n\nCosa troverai:\n• Materiale informativo\n• Possibilità di iscriverti come sostenitore\n• Gadget della campagna\n• Caffè e conversazione'},
    e4:{tag:'Evento',title:'Presentazione del programma completo',meta:['📅 Lunedì 20 aprile 2026','🕐 Ore 20:30','📍 Teatro Politeama','🎟️ Prenotazione obbligatoria'],text:'La serata più importante della campagna.\n\nPresenteremo il programma per i prossimi 5 anni: 12 capitoli, 48 proposte concrete.\n\n1. Mare e ambiente\n2. Scuole e giovani\n3. Lavoro e porto\n4. Mobilità e trasporti\n5. Cultura e turismo\n6. Sicurezza\n7. Welfare e anziani\n8. Sport\n9. Digitale e innovazione\n10. Commercio\n11. Bilancio e trasparenza\n12. Partecipazione civica\n\nPrenotazione: WhatsApp al 333-1234567.'}
  }
};

function openDetail(type, id) {
  const d = DETAIL_DATA[type]?.[id];
  if(!d) return;
  document.getElementById('detail-tag').textContent = d.tag || '';
  document.getElementById('detail-hdr').textContent = d.tag || 'Dettaglio';
  document.getElementById('detail-title').textContent = d.title || '';
  document.getElementById('detail-meta').innerHTML = (d.meta||[]).map(m=>`<span class="badge blu">${m}</span>`).join('');
  document.getElementById('detail-text').textContent = d.text || '';
  document.getElementById('detail-overlay').classList.add('open');
}
function closeDetail() {
  document.getElementById('detail-overlay').classList.remove('open');
}

// ── BACK GESTURE ─────────────────────────────────────────
document.addEventListener('keydown', e => {
  if(e.key === 'Escape') {
    if(document.getElementById('detail-overlay').classList.contains('open')) closeDetail();
    else if(document.getElementById('login-overlay').style.display === 'flex') hideAdminLogin();
  }
});

// ── SERVICE WORKER (PWA) ─────────────────────────────────
if('serviceWorker' in nav