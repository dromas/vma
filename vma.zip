      <div class="tab" onclick="switchAdminTab('news',this)">📰 Notizie</div>
      <div class="tab" onclick="switchAdminTab('push',this)">🔔 Push</div>
    </div>
    <div class="admin-sc">

      <!-- TAB EVENTI -->
      <div id="atab-events">
        <div class="form-card">
          <div class="form-card-title">➕ Nuovo evento</div>
          <label class="flabel">Titolo *</label>
          <input class="finput" type="text" placeholder="Es: Comizio in Piazza Mazzini" id="ev-title">
          <label class="flabel">Descrizione breve</label>
          <input class="finput" type="text" placeholder="Teaser breve" id="ev-short">
          <label class="flabel">Descrizione lunga</label>
          <textarea class="ftextarea" placeholder="Testo completo dell'evento..." id="ev-long"></textarea>
          <div class="frow">
            <div><label class="flabel">Data *</label><input class="finput" type="date" id="ev-date" style="margin-bottom:0;"></div>
            <div><label class="flabel">Ora *</label><input class="finput" type="time" id="ev-time" style="margin-bottom:0;"></div>
          </div>
          <div style="height:12px;"></div>
          <label class="flabel">Luogo *</label>
          <input class="finput" type="text" placeholder="Es: Piazza Mazzini, Viareggio" id="ev-place">
          <label class="flabel">Categoria</label>
          <select class="fselect" id="ev-cat"><option>Comizio</option><option>Gazebo</option><option>Dibattito</option><option>Incontro cittadini</option><option>Evento culturale</option></select>
          <button class="btn-primary rosso" onclick="addEvent()">✓ Pubblica evento</button>
        </div>
        <div style="display:flex;justify-content:space-between;align-items:center;padding:4px 14px 8px;">
          <span style="font-size:13px;font-weight:700;color:var(--testo);">Pubblicati</span>
          <span class="badge rosso" id="event-count">4</span>
        </div>
        <div id="admin-events-list">
          <div class="admin-item"><span class="admin-item-ico">🗓️</span><div class="admin-item-body"><div class="admin-item-title">Comizio — Piazza Mazzini</div><div class="admin-item-meta">📅 29 mar • 17:30 • P.za Mazzini</div></div><button class="btn-danger" onclick="showToast('Eliminato');this.closest('.admin-item').remove()">✕</button></div>
          <div class="admin-item"><span class="admin-item-ico">🗓️</span><div class="admin-item-body"><div class="admin-item-title">Tavola rotonda — Porto</div><div class="admin-item-meta">📅 05 apr • 10:00 • Camera di Commercio</div></div><button class="btn-danger" onclick="showToast('Eliminato');this.closest('.admin-item').remove()">✕</button></div>
          <div class="admin-item"><span class="admin-item-ico">🗓️</span><div class="admin-item-body"><div class="admin-item-title">Gazebo — Darsena</div><div class="admin-item-meta">📅 12 apr • 10:00 • P.za della Libertà</div></div><button class="btn-danger" onclick="showToast('Eliminato');this.closest('.admin-item').remove()">✕</button></div>
          <div class="admin-item"><span class="admin-item-ico">🗓️</span><div class="admin-item-body"><div class="admin-item-title">Presentazione programma</div><div class="admin-item-meta">📅 20 apr • 20:30 • Teatro Politeama</div></div><button class="btn-danger" onclick="showToast('Eliminato');this.closest('.admin-item').remove()">✕</button></div>
        </div>
