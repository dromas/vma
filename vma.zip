      </div>

      <!-- TAB NOTIZIE -->
      <div id="atab-news" style="display:none;">
        <div class="form-card">
          <div class="form-card-title">➕ Nuova notizia</div>
          <label class="flabel">Titolo *</label>
          <input class="finput" type="text" placeholder="Es: Il nostro piano per le scuole" id="news-title">
          <label class="flabel">Descrizione breve (teaser)</label>
          <input class="finput" type="text" placeholder="Max 120 caratteri" id="news-short">
          <label class="flabel">Contenuto completo</label>
          <textarea class="ftextarea" placeholder="Testo completo della notizia..." id="news-long" style="height:90px;"></textarea>
          <label class="flabel">Categoria</label>
          <select class="fselect" id="news-cat"><option>Programma</option><option>Campagna</option><option>Comune</option><option>Avviso</option></select>
          <label class="flabel">Notifica push</label>
          <select class="fselect" id="news-push"><option>Sì — invia notifica</option><option>No — pubblica solo</option></select>
          <button class="btn-primary" onclick="addNews()">✓ Pubblica notizia</button>
        </div>
        <div style="display:flex;justify-content:space-between;align-items:center;padding:4px 14px 8px;">
          <span style="font-size:13px;font-weight:700;color:var(--testo);">Pubblicate</span>
          <span class="badge blu" id="news-count">4</span>
        </div>
        <div id="admin-news-list">
          <div class="admin-item"><span class="admin-item-ico">📰</span><div class="admin-item-body"><div class="admin-item-title">Piano mare: riqualificazione Lungomare</div><div class="admin-item-meta">📅 20 mar · Programma</div></div><button class="btn-danger" onclick="showToast('Eliminato');this.closest('.admin-item').remove()">✕</button></div>
          <div class="admin-item"><span class="admin-item-ico">📰</span><div class="admin-item-body"><div class="admin-item-title">Incontro quartiere Migliarina</div><div class="admin-item-meta">📅 18 mar · Campagna</div></div><button class="btn-danger" onclick="showToast('Eliminato');this.closest('.admin-item').remove()">✕</button></div>
          <div class="admin-item"><span class="admin-item-ico">📰</span><div class="admin-item-body"><div class="admin-item-title">Carta d'identità: scadenza agosto 2026</div><div class="admin-item-meta">📅 15 mar · Avviso</div></div><button class="btn-danger" onclick="showToast('Eliminato');this.closest('.admin-item').remove()">✕</button></div>
          <div class="admin-item"><span class="admin-item-ico">📰</span><div class="admin-item-body"><div class="admin-item-title">Scuole: piano edilizia scolastica</div><div class="admin-item-meta">📅 10 mar · Programma</div></div><button class="btn-danger" onclick="showToast('Eliminato');this.closest('.admin-item').remove()">✕</button></div>
        </div>
        <div class="pb-safe"></div>
      </div>

      <!-- TAB PUSH -->
      <div id="atab-push" style="display:none;">
        <div class="form-card">
          <div class="form-card-title">📣 Invia notifica push</div>
          <label class="flabel">Titolo *</label>
          <input class="finput" type="text" placeholder="Es: Mancano 3 giorni al voto!" id="push-title">
          <label class="flabel">Messaggio *</label>
          <textarea class="ftextarea" placeholder="Testo della notifica..." id="push-body" style="height:68px;"></textarea>
          <label class="flabel">Destinatari</label>
          <select class="fselect"><option>Tutti gli utenti (423)</option><option>Quartiere Centro (128)</option><option>Quartiere Migliarina (87)</option><option>Quartiere Darsena (65)</option><option>Nuovi iscritti (34)</option></select>
          <div class="infobox warn" style="margin:0 0 12px;">
            <span class="infobox-icon">⚠️</span>
            <div class="infobox-text">Le notifiche vengono inviate immediatamente. Non è possibile annullare l'invio.</div>
          </div>
          <button class="btn-primary rosso" onclick="sendPush()">🔔 Invia notifica ora</button>
        </div>
        <div class="section-lbl">Inviate di recente</div>
        <div class="admin-item"><span class="admin-item-ico">🔔</span><div class="admin-item-body"><div class="admin-item-title">Reminder: Comizio Piazza Mazzini</div><div class="admin-item-meta">Oggi • 423 utenti • ✓ Consegnata</div></div></div>
        <div class="admin-item"><span class="admin-item-ico">📰</span><div class="admin-item-body"><div class="admin-item-title">Nuova notizia: Piano mare</div><div class="admin-item-meta">Ieri • 423 utenti • ✓ Consegnata</div></div></div>
        <div class="pb-safe"></div>
      </div>

    </div><!-- fine admin-sc -->
  </div><!-- fine admin-screen -->

  <!-- ===================== LOGIN OVERLAY ===================== -->
  <div id="login-overlay">
    <div style="font-size:26px;margin-bottom:6px;">🔐</div>
    <div class="login-logo">VIAREGGIO</div>
    <div class="login-sub">mon Amour</div>
    <div style="font-size:12px;color:rgba(255,255,255,.5);margin-bottom:22px;text-align:center;">Area riservata amministratori</div>
    <div id="login-error" class="login-error">Credenziali non valide. Riprova.</div>
    <label class="login-lbl">Email</label>
    <input class="login-input" type="email" id="login-email" placeholder="admin@viareggio.it" autocomplete="off">
    <label class="login-lbl">Password</label>
    <input class="login-input" type="password" id="login-pwd" placeholder="••••••••" onkeydown="if(event.key==='Enter')doLogin()">
    <button class="login-btn" onclick="doLogin()">Accedi al pannello →</button>
    <div class="login-hint">Demo: <a href="/cdn-cgi/l/email-protection" class="__cf_email__" data-cfemail="e283868f8b8ca2948b83908785858b8dcc8b96">[email&#160;protected]</a> / admin123</div>
    <div style="margin-top:18px;cursor:pointer;font-size:13px;color:rgba(255,255,255,.45);" onclick="hideAdminLogin()">← Torna all'app</div>
  </div>

  <!-- ===================== DETAIL OVERLAY ===================== -->
  <div class="detail-overlay" id="detail-overlay">
    <div class="detail-head">
      <span class="detail-back" onclick="closeDetail()">‹</span>
      <span class="detail-head-title" id="detail-hdr"></span>
    </div>
    <div class="detail-body">
      <div class="detail-tag" id="detail-tag"></div>
      <div class="detail-title" id="detail-title"></div>
      <div class="detail-meta" id="detail-meta"></div>
      <div class="detail-text" id="detail-text"></div>
